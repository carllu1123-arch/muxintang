{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": {
      "master": true,
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 22 * * *"
    }
  ]
}
