# =====================================================
# 牧心堂 · 环境变量模板
# 复制本文件为 .env.local 并填入真实值
# =====================================================
# 约定：
#   - NEXT_PUBLIC_*    → 暴露给浏览器（Vite/Next 同理）
#   - 其他            → 仅服务端可见
#   - 空值表示关闭该功能
# =====================================================

# -------- 端口（避免与灵境阁 3000 / 良朋社 3002 冲突） --------
PORT=3001

# =====================================================
# Supabase · 数据库 + 认证
# =====================================================
# 在 supabase.com 创建独立项目（命名建议 muxintang-prod）
# Project Settings → API 复制：
#   URL              → NEXT_PUBLIC_SUPABASE_URL
#   anon public key  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   service_role key → SUPABASE_SERVICE_ROLE_KEY（仅服务端，绝不暴露）
NEXT_PUBLIC_SUPABASE_URL=https://your-muxintang-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-muxintang-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 是否启用 mock 客户端（无 Supabase 项目时本地联调用）
# 生产环境务必不设或设为 false
# NEXT_PUBLIC_USE_MOCK_SUPABASE=true

# =====================================================
# Dify · AI 排盘解读
# =====================================================
# 至少填一个（Workflow 优先）：
#   DIFY_BAZI_WORKFLOW    → Workflow App 的 app_id（结果更稳定）
#   DIFY_BAZI_APP_ID      → Chatbot App 的 app_id
# 不填 → 自动走本地模板（永远不返回错误）
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_BAZI_WORKFLOW=
DIFY_BAZI_APP_ID=

# =====================================================
# Polar · 支付
# =====================================================
# 注册：https://polar.sh
# Polar Dashboard → Settings → Webhooks 添加：
#   URL:   https://your-domain.com/api/polar/webhook
#   Event: subscription.created / updated / canceled / revoked
#          order.paid / order.created
POLAR_WEBHOOK_SECRET=
# Polar API key（可选：服务端主动查订单）
POLAR_API_KEY=
# 结账链接（前端"立即开通"按钮跳转用）
NEXT_PUBLIC_POLAR_CHECKOUT_URL_MONTHLY=https://buy.polar.sh/your-monthly-product-id
NEXT_PUBLIC_POLAR_CHECKOUT_URL_YEARLY=https://buy.polar.sh/your-yearly-product-id

# =====================================================
# TTS · 文本转语音（排盘解读朗读 / 法语梵呗）
# =====================================================
# 当前走 /api/tts（已实现硅基流动 SiliconFlow 接入）
# 启用开关：API 路由内 readEnvSiliconflow()
SILICONFLOW_API_KEY=
SILICONFLOW_TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B

# =====================================================
# 对象存储 OSS（师兄师姐开放接入用）
# =====================================================
# 当前模式（不填则走 Supabase Storage）：
#   aliyun_oss   阿里云 OSS
#   tencent_cos  腾讯云 COS
#   s3           AWS S3 / 兼容协议（Cloudflare R2 / MinIO）
STORAGE_PROVIDER=

# -------- 阿里云 OSS --------
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=muxintang-prod
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 自定义 CDN 域名（可选）：https://cdn.muxintang.com
ALIYUN_OSS_CDN_DOMAIN=

# -------- 腾讯云 COS --------
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=muxintang-1300000000
TENCENT_COS_REGION=ap-shanghai

# -------- AWS S3 / Cloudflare R2 / MinIO（兼容 S3 协议） --------
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=muxintang
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://cdn.muxintang.com

# =====================================================
# 应用配置
# =====================================================
# 站点 URL（用于 OAuth 回调、邮件链接等）
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# 默认时区
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Shanghai

# 调试开关（生产环境务必不设或设为 false）
# NEXT_PUBLIC_DEBUG=true

# =====================================================
# 第三方服务（可选）
# =====================================================
# 邮件发送：每日晨音推送（/api/cron/daily-digest）
#   - 使用 Nodemailer + SMTP，兼容 Resend / SendGrid / Mailgun / 阿里云 DM / 自建 SMTP
#   - 任一字段缺失 → 自动进入 mock 模式（log 到控制台，不真发）
#   - 推荐：用 Resend（https://resend.com）开通后，host=smtp.resend.com，port=465
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
MAIL_FROM=noreply@muxintang.com

# Vercel Cron 鉴权
#   - 在 Vercel Dashboard → Project → Settings → Environment Variables 添加
#   - Vercel Cron 调用时会自动带 Authorization: Bearer <CRON_SECRET>
#   - 不设 → dev 模式（无鉴权），生产环境务必设置
CRON_SECRET=your-random-secret-min-32-chars

# 兼容：Resend API 模式（暂未启用，目前统一走 SMTP）
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@muxintang.com

# 监控（Sentry）
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# 分析（Plausible / Umami，自部署友好）
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=muxintang.com
